# Nexa Identity
# Central auth and verification service for Nexa products.
NEXT_PUBLIC_NEXA_IDENTITY_URL=http://127.0.0.1:4000
NEXA_IDENTITY_URL=http://127.0.0.1:4000

# Legacy Appwrite storage
# These remain only for data collections that have not been moved yet.
NEXT_PUBLIC_APPWRITE_PROJECT_ID=
APPWRITE_API_KEY=
APPWRITE_DATABASE_ID=
APPWRITE_STORAGE_ASSETS_COLLECTION_ID=
APPWRITE_GENERATED_IMAGES_COLLECTION_ID=
APPWRITE_STORAGE_USAGE_COLLECTION_ID=
APPWRITE_IMAGE_GENERATION_JOBS_COLLECTION_ID=
APPWRITE_PLAN_USAGE_COLLECTION_ID=
APPWRITE_MODEL_REGISTRY_COLLECTION_ID=
APPWRITE_MODEL_USAGE_COLLECTION_ID=
APPWRITE_BILLING_PLANS_COLLECTION_ID=
APPWRITE_SUBSCRIPTIONS_COLLECTION_ID=
APPWRITE_PAYMENTS_COLLECTION_ID=
APPWRITE_SUPPORT_TICKETS_COLLECTION_ID=
APPWRITE_SUPPORT_NOTES_COLLECTION_ID=
APPWRITE_ADMIN_AUDIT_LOGS_COLLECTION_ID=
APPWRITE_PROMOTIONS_COLLECTION_ID=
APPWRITE_PROMOTION_REWARDS_COLLECTION_ID=
APPWRITE_PROMOTION_ELIGIBILITY_RULES_COLLECTION_ID=
APPWRITE_PROMOTION_LIMITS_COLLECTION_ID=
APPWRITE_PROMOTION_SCHEDULES_COLLECTION_ID=
APPWRITE_PROMOTION_CODES_COLLECTION_ID=
APPWRITE_PROMOTION_ASSIGNMENTS_COLLECTION_ID=
APPWRITE_PROMOTION_REDEMPTIONS_COLLECTION_ID=
APPWRITE_PROMOTION_USAGE_EVENTS_COLLECTION_ID=
APPWRITE_PROMOTION_AUDIT_LOGS_COLLECTION_ID=
APPWRITE_PROMOTION_EXPERIMENTS_COLLECTION_ID=
APPWRITE_REFERRAL_CAMPAIGNS_COLLECTION_ID=
APPWRITE_REFERRAL_RELATIONSHIPS_COLLECTION_ID=

# Supabase
# Phase 1 stores billing subscriptions, payments, and plan usage here.
# Keep the service role key server-only. Never expose it as NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Nexa backend API
# Production: point this at a stable Cloudflare named tunnel route.
# Local development can use http://127.0.0.1:8000 instead.
NEXT_PUBLIC_API_URL=https://api.trynexa-ai.com
NEXA_IMAGE_API_URL=https://api.trynexa-ai.com

# Admin deployment split
# trynexa-ai.com and www.trynexa-ai.com can serve /admin by default.
# Only accounts whose email local part starts with admin. can stay in admin.
# Set NEXA_ADMIN_HOSTS to override the allowed admin hosts.
NEXA_ENABLE_ADMIN=false
NEXA_ADMIN_HOSTS=
NEXT_PUBLIC_NEXA_ADMIN_URL=

# Server-only web search. Never expose this as NEXT_PUBLIC_*.
TAVILY_API_KEY=
TAVILY_SEARCH_DEPTH=advanced
TAVILY_MAX_RESULTS=6
TAVILY_TIMEOUT_MS=9000

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_USER_STORAGE_BUCKET_NAME=
R2_TRAINING_EXPORTS_BUCKET_NAME=

# Legacy fallback for older local training export setups only.
R2_BUCKET_NAME=

# Billing checkout
# PayPal credentials and plan IDs live in Nexa Identity.
