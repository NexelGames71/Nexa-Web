NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id
NEXT_PUBLIC_APPWRITE_ADMIN_EMAILS=admin@example.com

# Server-only. Do not expose this in the browser.
APPWRITE_API_KEY=replace_with_server_key
APPWRITE_DATABASE_ID=replace_with_database_id
APPWRITE_CONVERSATIONS_COLLECTION_ID=replace_with_conversations_collection_id
APPWRITE_MESSAGES_COLLECTION_ID=replace_with_messages_collection_id
APPWRITE_USER_MEMORY_COLLECTION_ID=replace_with_user_memory_collection_id
APPWRITE_USER_PREFERENCES_COLLECTION_ID=replace_with_user_preferences_collection_id
APPWRITE_TRAINING_EXPORTS_COLLECTION_ID=replace_with_training_exports_collection_id
APPWRITE_TRAINING_EXPORT_FILES_COLLECTION_ID=replace_with_training_export_files_collection_id
APPWRITE_ADMIN_EMAILS=admin@example.com
TRAINING_EXPORT_CRON_SECRET=replace_with_cron_secret

# Cloudflare R2
R2_ACCOUNT_ID=replace_with_account_id
R2_ACCESS_KEY_ID=replace_with_access_key_id
R2_SECRET_ACCESS_KEY=replace_with_secret_access_key
# Legacy beta fallback. Prefer the domain-specific bucket names below.
R2_BUCKET_NAME=replace_with_legacy_or_training_export_bucket_name
R2_USER_STORAGE_BUCKET_NAME=replace_with_user_storage_bucket_name
R2_TRAINING_EXPORTS_BUCKET_NAME=replace_with_training_exports_bucket_name
